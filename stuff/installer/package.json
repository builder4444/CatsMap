{
  "name": "catsmap-installer",
  "version": "0.1.0",
  "description": "CatsMap GUI Installer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.catsmap.installer",
    "productName": "CatsMap Installer",
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Network"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
